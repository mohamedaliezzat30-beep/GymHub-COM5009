@model IEnumerable<GymHub.Models.FitnessContent>

@{
    ViewData["Title"] = "Fitness Content";
}

<h1 class="mb-4">Fitness Content</h1>

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-info mb-3">
            Upload New Content
        </a>
    </p>
}

<table class="table table-hover shadow-sm bg-white">
    <thead>
        <tr>
            <th>Image</th>
            <th>Title</th>
            <th>Description</th>

            @if (User.IsInRole("Admin"))
            {
                <th>Actions</th>
            }
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImagePath))
                    {
                        <a href="@item.ImagePath" target="_blank">
                            <img src="@item.ImagePath"
                                 width="150"
                                 class="img-thumbnail"
                                 alt="Fitness Image" />
                        </a>
                    }
                </td>

                <td>@item.Title</td>

                <td>@item.Description</td>

                @if (User.IsInRole("Admin"))
                {
                    <td>
                        <a asp-action="Edit"
                           asp-route-id="@item.FitnessContentId"
                           class="btn btn-sm btn-outline-primary">
                            Edit
                        </a>

                        <a asp-action="Details"
                           asp-route-id="@item.FitnessContentId"
                           class="btn btn-sm btn-outline-secondary">
                            Details
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.FitnessContentId"
                           class="btn btn-sm btn-outline-danger">
                            Delete
                        </a>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>