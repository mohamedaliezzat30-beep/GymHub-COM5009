@model GymHub.Models.GymClass

@{
    ViewData["Title"] = "Scheduled Class Details";
}

<h1>Scheduled Class Details</h1>

<div>
    <h4>Class Information</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-3">Class Name</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.ClassName)</dd>

        <dt class="col-sm-3">Class Date</dt>
        <dd class="col-sm-9">@Model.ClassDate.ToShortDateString()</dd>

        <dt class="col-sm-3">Start Time</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.StartTime)</dd>

        <dt class="col-sm-3">End Time</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.EndTime)</dd>

        <dt class="col-sm-3">Instructor</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Instructor)</dd>

        <dt class="col-sm-3">Difficulty Level</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.DifficultyLevel)</dd>

        <dt class="col-sm-3">Capacity</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Capacity)</dd>
    </dl>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.GymClassId" class="btn btn-primary">
        Edit
    </a>

    <a asp-action="Index" class="btn btn-secondary">
        Back to List
    </a>
</div>