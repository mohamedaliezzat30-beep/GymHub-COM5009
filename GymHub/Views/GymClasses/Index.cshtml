@model IEnumerable<GymHub.Models.GymClass>

@{
    ViewData["Title"] = "Class Schedule";

    var bookingCounts = ViewBag.BookingCounts as Dictionary<int, int>
        ?? new Dictionary<int, int>();
}

<h1 class="mb-4">Class Schedule</h1>

<p class="text-muted">
    View the gym classes currently available to members.
</p>

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-success">
            Add Scheduled Class
        </a>
    </p>
}

<table class="table table-hover shadow-sm bg-white">
    <thead>
        <tr>
            <th>Class Name</th>
            <th>Date</th>
            <th>Time</th>
            <th>Instructor</th>
            <th>Difficulty</th>
            <th>Capacity</th>
            <th>Booked</th>
            <th>Remaining</th>
            <th>Status</th>

            @if (User.IsInRole("Admin"))
            {
                <th></th>
            }
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            var booked = bookingCounts.ContainsKey(item.GymClassId)
            ? bookingCounts[item.GymClassId]
            : 0;

            var remaining = item.Capacity - booked;
            var isAvailable = remaining > 0;

            <tr>
                <td>@item.ClassName</td>
                <td>@item.ClassDate.ToShortDateString()</td>
                <td>@item.StartTime - @item.EndTime</td>
                <td>@item.Instructor</td>
                <td>@item.DifficultyLevel</td>
                <td>@item.Capacity</td>
                <td>@booked</td>
                <td>@remaining</td>
                <td>
                    @if (isAvailable)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Full</span>
                    }
                </td>

                @if (User.IsInRole("Admin"))
                {
                    <td>
                        <a asp-action="Edit"
                           asp-route-id="@item.GymClassId"
                           class="btn btn-sm btn-outline-primary">
                            Edit
                        </a>

                        <a asp-action="Details"
                           asp-route-id="@item.GymClassId"
                           class="btn btn-sm btn-outline-secondary">
                            Details
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.GymClassId"
                           class="btn btn-sm btn-outline-danger">
                            Delete
                        </a>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>
