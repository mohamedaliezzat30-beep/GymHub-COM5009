@model GymHub.Models.Booking

@{
    ViewData["Title"] = "Book a Class";
}

<h1 class="mb-3">Book a Class</h1>

<p class="text-muted">
    Choose one of the available scheduled classes below.
</p>

<hr />

<div class="row">
    <div class="col-md-6">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="alert alert-info">
                Booking for: <strong>@ViewBag.MemberName</strong>
            </div>

            <div class="form-group mb-3">
                <label asp-for="GymClassId" class="control-label">Available Classes</label>

                <select asp-for="GymClassId"
                        class="form-control"
                        asp-items="ViewBag.GymClassId">
                    <option value="">-- Select a Class --</option>
                </select>

                <span asp-validation-for="GymClassId" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit"
                       value="Confirm Booking"
                       class="btn btn-warning" />

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Back to My Bookings
                </a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}