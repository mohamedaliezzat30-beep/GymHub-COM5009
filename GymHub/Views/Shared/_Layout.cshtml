<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GymHub</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GymHub.styles.css" asp-append-version="true" />
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">

                <a class="navbar-brand fw-bold"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">
                    GymHub
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent"
                        aria-controls="navbarContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Memberships"
                                       asp-action="Index">
                                        Manage Memberships
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="GymClasses"
                                       asp-action="Index">
                                        Manage Classes
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Bookings"
                                       asp-action="Index">
                                        Manage Bookings
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="FitnessContents"
                                       asp-action="Index">
                                        Manage Fitness Content
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="ActivityLogs"
                                       asp-action="Index">
                                        Activity Log
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="MembershipSignup"
                                       asp-action="Join">
                                        Join GymHub
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="MyMembership"
                                       asp-action="Index">
                                        My Membership
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="GymClasses"
                                       asp-action="Index">
                                        Class Schedule
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Bookings"
                                       asp-action="Index">
                                        My Bookings
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="FitnessContents"
                                       asp-action="Index">
                                        Fitness Content
                                    </a>
                                </li>
                            }
                        }

                    </ul>

                    <partial name="_LoginPartial" />

                </div>

            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            &copy; 2026 GymHub - Gym Membership and Fitness Management System |
            Developed by Mohamed Abdelrahman
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>